# XKC Server Configuration
# Copy to .env and fill in your values

# Required — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
XKC_SECRET_KEY=your-secret-key-here

# Admin account (created on first boot if no admin exists)
XKC_ADMIN_USERNAME=admin
XKC_ADMIN_PASSWORD=changeme

# Public URL of your server (used for OAuth callbacks and config exports)
XKC_PUBLIC_URL=http://localhost:3001

# Storage directory (maps to Docker volume)
XKC_DATA_DIR=/data

# Upload size limit in MB
XKC_MAX_UPLOAD_MB=500

# Number of parallel analysis workers (CPU-bound, set to CPU cores - 1)
XKC_ANALYSIS_WORKERS=2

# Optional: Spotify API credentials (for liked tracks sync)
# Get from: https://developer.spotify.com/dashboard
XKC_SPOTIFY_CLIENT_ID=
XKC_SPOTIFY_CLIENT_SECRET=
